{
  "info": {
    "_postman_id": "6f7d8d8a-4f18-4e2d-9e0f-9a9db0f1d001",
    "name": "Library Security API",
    "description": "Postman collection for testing authentication, registration, and user management endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth - Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "login"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const body = pm.response.json();",
              "pm.environment.set('accessToken', body.accessToken);",
              "pm.environment.set('refreshToken', body.refreshToken);",
              "pm.test('Access token exists', function () {",
              "  pm.expect(body.accessToken).to.be.a('string').and.not.empty;",
              "});",
              "pm.test('Refresh token exists', function () {",
              "  pm.expect(body.refreshToken).to.be.a('string').and.not.empty;",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Auth - Register Success",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"newuser@example.com\",\n  \"soDienThoai\": \"0987654321\",\n  \"hoDem\": \"Nguyen\",\n  \"ten\": \"User\",\n  \"password\": \"password123\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/register",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "register"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const body = pm.response.json();",
              "pm.test('User ID exists', function () {",
              "  pm.expect(body.maNguoiDung).to.be.a('string').and.not.empty;",
              "});",
              "pm.test('Email is correct', function () {",
              "  pm.expect(body.email).to.equal('newuser@example.com');",
              "});",
              "pm.test('Message contains success', function () {",
              "  pm.expect(body.message).to.include('thành công');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Auth - Register Duplicate Email",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"admin\",\n  \"soDienThoai\": \"9999999999\",\n  \"hoDem\": \"Test\",\n  \"ten\": \"Duplicate\",\n  \"password\": \"password123\"\n}"
