{
  "info": {
    "_postman_id": "6f7d8d8a-4f18-4e2d-9e0f-9a9db0f1d001",
    "name": "Library Security API",
    "description": "Postman collection for testing login, me, refresh, logout, and role-protected endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth - Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "login"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const body = pm.response.json();",
              "pm.environment.set('accessToken', body.accessToken);",
              "pm.environment.set('refreshToken', body.refreshToken);",
              "pm.test('Access token exists', function () {",
              "  pm.expect(body.accessToken).to.be.a('string').and.not.empty;",
              "});",
              "pm.test('Refresh token exists', function () {",
              "  pm.expect(body.refreshToken).to.be.a('string').and.not.empty;",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Auth - Me",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/auth/me",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "me"
          ]
        }
      }
    },
    {
      "name": "Auth - Refresh",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/refresh",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "refresh"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const body = pm.response.json();",
              "pm.environment.set('accessToken', body.accessToken);",
              "pm.environment.set('refreshToken', body.refreshToken);",
              "pm.test('Access token rotated', function () {",
              "  pm.expect(body.accessToken).to.be.a('string').and.not.empty;",
              "});",
              "pm.test('Refresh token rotated', function () {",
              "  pm.expect(body.refreshToken).to.be.a('string').and.not.empty;",
              "});"
            ]
          }
        }
      ]
    },
